generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  username  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Class {
  id          String  @id @default(cuid())
  name        String
  section     String
  room        String?
  maxCapacity Int     @default(30)
  isActive    Boolean @default(true)
  teacherId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  students    Student[]

  @@unique([name, section])
}

model Parent {
  id                 String    @id @default(cuid())
  username           String?
  phone              String    @unique
  password           String
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  students           Student[]

  @@index([username])
}

model Student {
  id          String  @id @default(cuid())
  admissionNo String  @unique
  rollNo      String
  classId     String?
  classRef    Class?  @relation(fields: [classId], references: [id])
  parentId    String?
  parent      Parent? @relation(fields: [parentId], references: [id], onDelete: SetNull)
  className   String? @map("class")
  section     String?
  firstName          String
  middleName         String?
  lastName           String
  gender             Gender
  dob                DateTime?
  category           String?
  religion           String?
  caste              String?
  mobileNumber       String?
  email              String?
  admissionDate      DateTime?
  bloodGroup         String?
  house              String?
  height             String?
  weight             String?
  measurementDate    DateTime?
  fatherName         String?
  fatherPhone        String?
  fatherOccupation   String?
  motherName         String?
  motherPhone        String?
  motherOccupation   String?
  guardianType       String?
  guardianName       String?
  guardianRelation   String?
  guardianEmail      String?
  guardianPhone      String?
  guardianOccupation String?
  guardianAddress    String?
  currentAddress     String?
  permanentAddress   String?
  feeStatus          FeeStatus     @default(PENDING)
  attendance         Float?
  transportRequired  Boolean       @default(false)
  status             StudentStatus @default(ACTIVE)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  attendanceRecords  Attendance[]

  @@index([classId])
  @@index([parentId])
}

model Attendance {
  id         String           @id @default(cuid())
  date       DateTime         @db.Date
  status     AttendanceStatus
  notes      String?          @db.Text
  studentId  String?
  student    Student?         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  staffId    String?
  markedById String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([date, studentId])
  @@index([date])
  @@index([studentId])
}

model Notice {
  id          String       @id @default(cuid())
  title       String
  description String       @db.Text
  type        NoticeType
  status      NoticeStatus @default(DRAFT)
  publishDate DateTime?
  expiryDate  DateTime?
  attachments String[]
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([type])
  @@index([publishDate])
}

model NoticeNotificationState {
  id         String   @id @default(cuid())
  userId     String
  userType   String
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, userType])
  @@index([userId, userType])
}

model Broadcast {
  id            String          @id @default(cuid())
  subject       String
  content       String          @db.Text
  status        BroadcastStatus @default(DRAFT)
  recipientType RecipientType
  targetClassId String?
  channels      Json?
  scheduledFor  DateTime?
  sentAt        DateTime?
  createdById   String
  createdByName String
  totalRecipients Int @default(0)
  deliveredCount  Int @default(0)
  readCount       Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([recipientType])
}

model CalendarEvent {
  id              String    @id @default(cuid())
  title           String
  description     String?
  startDate       DateTime
  endDate         DateTime?
  startTime       String?
  endTime         String?
  type            String
  location        String?
  audience        String[]
  showOnFrontSite Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([startDate])
  @@index([type])
}

model FeeType {
  id             String        @id @default(cuid())
  name           String
  description    String?
  frequency      FeeFrequency
  amount         Float
  dueDay         Int?
  dueMonth       Int?
  applicableTo   String?
  isActive       Boolean       @default(true)
  academicYearId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  assignments    StudentFee[]
  payments       FeePayment[]
}

model StudentFee {
  id        String           @id @default(cuid())
  studentId String
  feeTypeId String
  feeType   FeeType          @relation(fields: [feeTypeId], references: [id], onDelete: Cascade)
  amount    Float
  dueDate   DateTime
  status    FeePaymentStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([studentId, feeTypeId, dueDate])
  @@index([studentId])
  @@index([status])
  @@index([dueDate])
}

model FeePayment {
  id            String        @id @default(cuid())
  receiptNo     String        @unique @default(cuid())
  studentId     String
  feeTypeId     String
  feeType       FeeType       @relation(fields: [feeTypeId], references: [id])
  amount        Float
  paymentMethod PaymentMethod
  referenceId   String?
  remarks       String?
  paidAt        DateTime      @default(now())
  createdAt     DateTime      @default(now())

  @@index([studentId])
  @@index([feeTypeId])
  @@index([paidAt])
}

model SchoolSettings {
  id               String  @id @default("default")
  schoolName       String?
  schoolLogo       String? @db.Text
  phoneNumber      String?
  officialEmail    String?
  fullAddress      String?
  boardAffiliation String?
  schoolTimezone   String?
  dateFormat       String  @default("DD/MM/YYYY")
  timeFormat       String  @default("12 Hour")
  timezone         String  @default("GMT+5:30")
  language         String  @default("English (US)")
  region           String  @default("India")
  workingDays      Json    @default("[\"mon\", \"tue\", \"wed\", \"thu\", \"fri\"]")
  startTime        String  @default("08:00")
  endTime          String  @default("15:00")
  saturdayEndTime  String  @default("12:30")
  terms            Json    @default("[]")
  attendanceMode   String  @default("daily")
  dailyThreshold   Int     @default(85)
  monthlyThreshold Int     @default(75)
  gradingScale     String  @default("Standard 4.0 Scale")
  grades           Json    @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum FeeStatus {
  PAID
  DUE
  PENDING
}

enum StudentStatus {
  ACTIVE
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
}

enum NoticeType {
  ACADEMIC
  EVENT
  HOLIDAY
  URGENT
  ADMIN
}

enum NoticeStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}

enum RecipientType {
  ALL_STUDENTS
  ALL_STAFF
  ALL_PARENTS
  CLASS
  INDIVIDUAL
}

enum FeeFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME
}

enum FeePaymentStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  CHEQUE
}
